[
  {
    "id": "login-report-failed-001",
    "description": "登录成功通过，但 token 过期检查失败时，报告必须只把失败归因到过期步骤。",
    "plan": {
      "id": "plan-login-report",
      "title": "登录执行计划",
      "source": "eval/login",
      "requirements": [
        {
          "id": "REQ-001",
          "title": "登录成功",
          "description": "验证码正确且未过期时登录成功。",
          "keywords": ["登录成功", "验证码"],
          "priority": "high",
          "source": "eval/login"
        },
        {
          "id": "REQ-002",
          "title": "Token 过期拒绝",
          "description": "access token 过期时接口必须拒绝访问。",
          "keywords": ["token", "过期", "拒绝"],
          "priority": "high",
          "source": "eval/login"
        }
      ],
      "scope": {
        "in_scope": ["登录成功", "Token 过期拒绝"],
        "out_of_scope": [],
        "assumptions": ["测试账号和 token fixture 已准备"],
        "risks": ["鉴权和权限边界需要重点验证"]
      },
      "steps": [
        {
          "id": "TP-001",
          "title": "验证登录成功",
          "objective": "调用登录接口并确认成功响应。",
          "requirement_ids": ["REQ-001"],
          "test_types": ["functional"],
          "priority": "high",
          "tool": "http",
          "tool_args": { "method": "POST", "path": "/api/v1/login" },
          "success_criteria": ["返回 200"]
        },
        {
          "id": "TP-002",
          "title": "验证 token 过期拒绝",
          "objective": "使用过期 token 调用 profile 接口。",
          "requirement_ids": ["REQ-002"],
          "test_types": ["exception", "permission"],
          "priority": "high",
          "tool": "http",
          "tool_args": { "method": "GET", "path": "/api/v1/profile" },
          "success_criteria": ["返回 401"]
        }
      ]
    },
    "tool_runs": [
      {
        "id": "run-1",
        "plan_step_id": "TP-001",
        "tool": "http",
        "status": "passed",
        "command": ["POST", "/api/v1/login"],
        "exit_code": 0,
        "output_summary": "HTTP 200 login success",
        "artifact_paths": ["data/test-artifacts/run-1/response.txt"]
      },
      {
        "id": "run-2",
        "plan_step_id": "TP-002",
        "tool": "http",
        "status": "failed",
        "command": ["GET", "/api/v1/profile"],
        "exit_code": 1,
        "output_summary": "HTTP 401 token expired",
        "artifact_paths": ["data/test-artifacts/run-2/response.txt"]
      }
    ],
    "expected": {
      "status": "failed",
      "covered_requirement_ids": ["REQ-001"],
      "uncovered_requirement_ids": ["REQ-002"],
      "defect_step_ids": ["TP-002"],
      "reason_classifications": {
        "TP-002": "auth_failure"
      },
      "markdown_fragments": [
        "# Test Execution Report: report-plan-login-report",
        "| REQ-001 | yes |",
        "| REQ-002 | no |",
        "TP-002: HTTP 401 token expired",
        "data/test-artifacts/run-2/response.txt"
      ],
      "forbidden_fragments": ["REQ-003", "passed=2"]
    }
  },
