  {
    "id": "refund-flow-execution-001",
    "description": "退款业务流中创建和幂等检查通过，但审计查询失败时，报告应保留已通过覆盖并定位失败审计步骤。",
    "plan": {
      "id": "plan-refund-flow-execution",
      "title": "退款业务流执行计划",
      "source": "eval/execution/refund-flow",
      "requirements": [
        {
          "id": "REQ-REFUND-FLOW-001",
          "title": "创建退款成功",
          "description": "提交退款请求后，系统应返回 201 并生成退款编号。",
          "keywords": ["refund", "201", "refund_id"],
          "priority": "critical",
          "source": "eval/execution/refund-flow"
        },
        {
          "id": "REQ-REFUND-FLOW-002",
          "title": "退款幂等检查通过",
          "description": "同一业务请求的幂等检查应返回已存在退款记录。",
          "keywords": ["idempotency", "refund_id"],
          "priority": "high",
          "source": "eval/execution/refund-flow"
        },
        {
          "id": "REQ-REFUND-FLOW-003",
          "title": "退款审计记录可查询",
          "description": "退款创建后应能查询到审计记录。",
          "keywords": ["audit", "refund"],
          "priority": "high",
          "source": "eval/execution/refund-flow"
        }
      ],
      "scope": {
        "in_scope": ["创建退款", "幂等检查", "审计查询"],
        "out_of_scope": ["真实支付网关回调"],
        "assumptions": ["HTTP 响应由测评脚本注入"],
        "risks": ["资金路径必须保留审计证据"]
      },
      "steps": [
        {
          "id": "TP-REFUND-FLOW-001",
          "title": "提交退款创建请求",
          "objective": "提交退款请求并检查创建状态。",
          "requirement_ids": ["REQ-REFUND-FLOW-001"],
          "test_types": ["functional"],
          "priority": "critical",
          "tool": "http",
          "tool_args": {
            "method": "POST",
            "path": "/api/v1/refunds",
            "headers": { "X-Request-ID": "eval-refund-flow" },
            "json": {
              "order_id": "order_eval_001",
              "amount": 100,
              "idempotency_key": "refund-eval-001"
            },
            "expected_status": 201
          },
          "success_criteria": ["返回 201"]
        },
        {
          "id": "TP-REFUND-FLOW-002",
          "title": "查询退款幂等结果",
          "objective": "验证幂等请求能关联到同一退款编号。",
          "requirement_ids": ["REQ-REFUND-FLOW-002"],
          "test_types": ["functional", "exception"],
          "priority": "high",
          "tool": "http",
          "tool_args": {
            "method": "GET",
            "path": "/api/v1/refunds/rf_001/idempotency-check",
            "expected_status": 200
          },
          "success_criteria": ["返回 200"]
        },
        {
          "id": "TP-REFUND-FLOW-003",
          "title": "查询退款审计记录",
          "objective": "确认退款审计记录可查询。",
          "requirement_ids": ["REQ-REFUND-FLOW-003"],
          "test_types": ["security", "functional"],
          "priority": "high",
          "tool": "http",
          "tool_args": {
            "method": "GET",
            "path": "/api/v1/refunds/rf_001/audit",
            "expected_status": 200
          },
          "success_criteria": ["返回 200"]
        }
      ]
    },
    "http_responses": [
      {
        "method": "POST",
        "path": "/api/v1/refunds",
        "status": 201,
        "json": { "refund_id": "rf_001", "status": "created" }
      },
      {
        "method": "GET",
        "path": "/api/v1/refunds/rf_001/idempotency-check",
        "status": 200,
        "json": { "refund_id": "rf_001", "idempotent": true }
      },
      {
        "method": "GET",
        "path": "/api/v1/refunds/rf_001/audit",
        "status": 503,
        "json": { "error": "audit store unavailable" }
      }
    ],
    "expected": {
      "report_status": "failed",
      "tool_run_statuses": {
        "TP-REFUND-FLOW-001": "passed",
        "TP-REFUND-FLOW-002": "passed",
        "TP-REFUND-FLOW-003": "failed"
      },
      "covered_requirement_ids": [
        "REQ-REFUND-FLOW-001",
        "REQ-REFUND-FLOW-002"
      ],
      "uncovered_requirement_ids": ["REQ-REFUND-FLOW-003"],
      "defect_step_ids": ["TP-REFUND-FLOW-003"],
      "output_fragments": [
        "POST /api/v1/refunds returned 201; expected [201].",
        "GET /api/v1/refunds/rf_001/idempotency-check returned 200; expected [200].",
        "GET /api/v1/refunds/rf_001/audit returned 503; expected [200]."
      ]
    }
  },
  {
    "id": "http-header-blocked-execution-001",
    "description": "HTTP 工具拒绝未授权 header 时，报告应 blocked，并把需求标记为未覆盖。",
    "plan": {
      "id": "plan-http-header-blocked-execution",
      "title": "HTTP header 权限边界执行计划",
      "source": "eval/execution/http-header-blocked",
      "requirements": [
        {
          "id": "REQ-HTTP-HEADER-001",
          "title": "执行工具不得透传敏感 header",
          "description": "默认 HTTP adapter 不允许 Authorization header 透传到被测服务。",
          "keywords": ["Authorization", "header", "allowlist"],
          "priority": "high",
          "source": "eval/execution/http-header-blocked"
        }
      ],
      "scope": {
        "in_scope": ["header allowlist"],
        "out_of_scope": ["真实认证服务"],
        "assumptions": ["HTTP adapter 使用默认 allowed headers"],
        "risks": ["错误透传敏感 header 会扩大工具执行权限"]
      },
      "steps": [
        {
          "id": "TP-HEADER-BLOCKED-001",
          "title": "尝试透传 Authorization header",
          "objective": "验证 HTTP 工具会拒绝未授权 header。",
          "requirement_ids": ["REQ-HTTP-HEADER-001"],
          "test_types": ["security", "permission"],
          "priority": "high",
          "tool": "http",
          "tool_args": {
            "method": "GET",
            "path": "/api/v1/users/me",
            "headers": { "Authorization": "Bearer eval-secret" },
            "expected_status": 200
          },
          "success_criteria": ["工具应阻止未授权 header"]
        }
      ]
    },
    "http_responses": [
      {
        "method": "GET",
        "path": "/api/v1/users/me",
        "status": 200,
        "json": { "id": "user_eval_001" }
      }
    ],
    "expected": {
      "report_status": "blocked",
      "tool_run_statuses": { "TP-HEADER-BLOCKED-001": "blocked" },
      "covered_requirement_ids": [],
      "uncovered_requirement_ids": ["REQ-HTTP-HEADER-001"],
      "defect_step_ids": [],
      "blocked_step_ids": ["TP-HEADER-BLOCKED-001"],
      "output_fragments": [
        "HTTP tool blocked",
        "HTTP header(s) not allowed: Authorization"
      ]
    }
  }
]
